#BT
CONFIG_BT_PERIPHERAL_PREF_MIN_INT=12/*レポート頻度が60Hz程度を超えないように制限*/
CONFIG_BT_PERIPHERAL_PREF_MAX_INT=12/*レポート頻度が60Hz程度を超えないように制限*/

# 左（central）
if SHIELD_KOBITOKEY_LEFT
config ZMK_KEYBOARD_NAME
    default "KobitoKey"
endif

# 左右共通
if SHIELD_KOBITOKEY_LEFT || SHIELD_KOBITOKEY_RIGHT
config ZMK_SPLIT
    default y
config ZMK_POINTING
    default y
config SPI
    default y
endif
